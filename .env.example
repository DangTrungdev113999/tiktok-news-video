# Copy to .env and fill in. Written automatically by `npm run init` — you
# normally don't need to edit this by hand.

# ElevenLabs API key — required only if you don't provide your own MP3
# narration (the pipeline falls back to ElevenLabs v3 TTS).
ELEVENLABS_API_KEY=

# Default ElevenLabs voice_id used for TTS narration.
ELEVENLABS_VOICE_ID=FHhpndubmejSghqiumSv
